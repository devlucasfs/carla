@target
' Specify the file who your entrypoint is
main: "src/main.crl"

' You can use here to specify the output format.
' Is available: "native-bin", "static-archive" or "shared-object"
output: { format: "native-bin" }

@extensors
' You can put more git repositories here.
' Each repository will be checked when you try to install an extensor.
' "git@github.com:Carla-repos/extensors.git" is the default (official) repository.
repositories: [ "git@github.com:Carla-repos/extensors.git" ]
